DATABASE_URL="postgresql://all_personal_projects_dev:all_personal_projects_dev@localhost:5432/all_personal_projects_dev"
DATABASE_SCHEMA_NAME="mail"
MAIL_AGENT_HTTP_HOST="127.0.0.1"
MAIL_AGENT_HTTP_PORT="3070"
MAIL_AGENT_POLL_INTERVAL_MS="60000"
MAIL_AGENT_AI_RULES_DELETE="Generell Werbung; Ausnahmen siehe Behalten.||Phishing."
MAIL_AGENT_AI_RULES_KEEP="Nachrichten, die eine Antwort erwarten.||Wichtige Vertragsänderungen oder Inhalte mit notwendiger Aktion.||Rechnungen und finale Bestellbestätigungen."
MAIL_AGENT_AI_RULES_SUMMARY="Maximal 50 Worte, außer der Inhalt erfordert mehr für Vollständigkeit.||Wichtige Details nicht verlieren: Beträge, Datum, Produkte, Titel, Sendungsnummern.||Werbung: relevante Produkte oder Kategorien benennen.||Streamingdienste: neue/entfernte Titel möglichst vollständig nennen."
MAIL_AGENT_GMAIL_FILTER_QUERY="in:inbox AND NOT (from:@gmail.com OR from:@googlemail.com OR category:social)"
MAIL_AGENT_LABEL_AI_LABEL_PREFIX="ai-managed"
MAIL_AGENT_LABEL_KEEP="keep"
MAIL_AGENT_LABEL_DELETE="soft-delete"
MAIL_AGENT_LABEL_HIDDEN="hidden"
MAIL_AGENT_UNDO_TOKEN_SECRET="mail-agent-local-undo-secret"
