{
  "name": "mail-agent",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "echo 'not implemented'",
    "start": "bun src/index.ts",
    "prisma": "prisma",
    "generate:prisma": "prisma generate",
    "gmail:auth": "bun src/gmail/generate-refresh-token.ts",
    "cursor:clear": "bun src/cli/clear-cursor.ts",
    "lint": "bunx eslint .",
    "check-types": "tsc --noEmit",
    "test": "echo 'no tests'",
    "fix": "bunx eslint --fix . && bun run format",
    "format": "prettier --write . --ignore-path ../../.prettierignore",
    "format:check": "prettier --check . --ignore-path ../../.prettierignore"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@types/debug": "^4.1.12",
    "debug": "^4.4.3",
    "dotenv": "^17.2.3",
    "googleapis": "^150.0.1",
    "openai": "^4.104.0",
    "pg": "^8.17.2",
    "prisma": "^7.3.0",
    "ts-pattern": "^5.3.1",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/bun": "^1.3.6",
    "@types/node": "^24.9.1",
    "eslint": "^9.34.0",
    "typescript": "^5.9.2"
  }
