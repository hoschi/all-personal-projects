{
  "name": "@repo/tools",
  "version": "0.0.0",
  "private": true,
  "bin": {
    "initproject": "./src/init.ts"
  },
  "exports": {
    "./*": "./src/*.ts"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/bun": "^1.3.6",
    "eslint": "^9.34.0",
    "syncpack": "^14.3.0"
  },
  "scripts": {
    "build": "echo 'not implemented'",
    "init-fresh-clone": "bun run src/init-fresh-clone.ts",
    "fetch-ai-docs": "bun run src/fetch-ai-docs.ts",
    "sync-main-rules": "bun run src/sync-main-rules.ts",
    "lint": "bunx eslint .",
    "check-types": "tsc --noEmit",
    "fix": "bunx eslint --fix .; bun run format",
    "syncpack:check": "cd ../.. && syncpack lint --dependency-types prod,dev,peer,overrides,pnpmOverrides,resolutions --specifier-types exact,major,minor,range,range-complex,range-major,range-minor,workspace-protocol --source 'package.json' --source 'apps/*/package.json' --source 'packages/*/package.json' --source '!apps/**/.output/**/package.json'",
    "syncpack:fix": "cd ../.. && syncpack fix --dependency-types prod,dev,peer,overrides,pnpmOverrides,resolutions --specifier-types exact,major,minor,range,range-complex,range-major,range-minor,workspace-protocol --source 'package.json' --source 'apps/*/package.json' --source 'packages/*/package.json' --source '!apps/**/.output/**/package.json'",
    "format": "prettier --write . --ignore-path ../../.prettierignore",
    "format:check": "prettier --check . --ignore-path ../../.prettierignore",
    "test": "echo 'no tests'"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.2.0",
    "commander": "^14.0.3"
  }
}
