DATABASE_URL="postgresql://all_personal_projects_dev:all_personal_projects_dev@localhost:5432/all_personal_projects_dev"
DATABASE_SCHEMA_NAME="yt"
YOUTUBE_API_KEY="your_youtube_data_api_v3_key"

# Pfad zum eigenen Knowledge-Base-Vault (wird von `relocate-plugin-outputs`
# genutzt, um `obsidian://`-Links inline zu patchen). Muss ein lokales
# Verzeichnis sein.
USER_KB_VAULT_PATH="/absolute/path/to/your/knowledge-base"

# Optional: Pfad zum OHS-Cross-Vault-Wrapper für Pass-5-Discovery in der
# Enrichment-Pipeline. Default ist `ohs-search-merged.sh` im $PATH —
# wenn dein Wrapper woanders liegt, hier den absoluten Pfad eintragen.
OHS_WRAPPER_PATH="ohs-search-merged.sh"

# Optional: Pfad zum Nightly-Log (wird von `check-nightly-health` gelesen).
# Default ist `~/Library/Logs/yt-pipeline-nightly.log`. Wenn dein LaunchAgent/
# Scheduler den Log unter einem anderen Namen schreibt, hier eintragen.
# YT_PIPELINE_NIGHTLY_LOG_PATH="/absolute/path/to/your-nightly.log"
