{
  "name": "@repo/yt-notes-scripts",
  "version": "0.0.0",
  "private": true,
  "exports": {
    "./db": "./src/db.ts",
    "./*": "./src/*.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "bunx eslint .",
    "check-types": "tsc --noEmit",
    "fix": "bunx eslint --fix . && bun run format",
    "format": "prettier --write . --ignore-path ../../.prettierignore",
    "format:check": "prettier --check . --ignore-path ../../.prettierignore",
    "test": "bun test",
    "test:db": "bun test ./src/check-nightly-health.e2e.ts ./src/recompute-plain-from-srt.e2e.ts",
    "prisma": "prisma",
    "generate:prisma": "prisma generate",
    "migrate:dev": "prisma migrate dev",
    "expand-legacy-links": "bun run src/expand_legacy_links.ts",
    "classify-channels": "bun run src/classify_channels.ts",
    "relocate-plugin-outputs": "bun run src/relocate_plugin_outputs.ts"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/bun": "^1.3.6",
    "@types/node": "^24.9.1",
    "@types/pg": "^8.16.0",
    "eslint": "^9.34.0",
    "prisma": "^7.3.0",
    "tiny-invariant": "^1.3.3",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@aj-archipelago/subvibe": "^1.0.12",
    "@inquirer/prompts": "^8.2.0",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "axios": "^1.13.1",
    "commander": "^14.0.3",
    "dotenv": "^17.2.3",
    "pg": "^8.17.2",
    "yaml": "^2.9.0"
  }
}
